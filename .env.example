# Listmonk Stack — Env-Vars (Coolify setzt diese fuer den Service)
# Werte werden in Coolify > Service > Environment Variables gepflegt
# UND im Vault gespiegelt unter Service "listmonk"

# Coolify-Magic-Vars (werden automatisch befuellt):
# SERVICE_FQDN_LISTMONK_9000    → mailings.fever-context.de
# SERVICE_PASSWORD_POSTGRES     → autogen, persistent
# SERVICE_PASSWORD_LISTMONKADMIN → autogen, persistent (initiales Admin-PW)

# Falls Magic-Vars NICHT genutzt werden, hier die manuellen Slots:
# LISTMONK_FQDN=mailings.fever-context.de
# LISTMONK_ADMIN_USER=admin
# LISTMONK_ADMIN_PASSWORD=<openssl rand -hex 24>
# POSTGRES_PASSWORD=<openssl rand -hex 32>

# === SMTP (im Listmonk-Web-UI gesetzt, NICHT als Env-Var) ===
# Settings -> SMTP:
#   Host:     w01XXXX.kasserver.com   (all-inkl Mailbox-Server fuer info@fever-events.de)
#   Port:     465 (SSL) oder 587 (STARTTLS)
#   Auth:     LOGIN
#   Username: <Mailbox-Login von info@fever-events.de bei all-inkl>
#   Password: <Mailbox-Passwort>
#   From:     "FEVER EVENTS <info@fever-events.de>"

# === Feverevents-DJ-Sync (in feverevents-dj .env) ===
# LISTMONK_API_URL=https://mailings.fever-context.de
# LISTMONK_API_USER=feverevents-dj-bot
# LISTMONK_API_TOKEN=<aus Listmonk: Settings -> API -> Create User -> Tokens>
